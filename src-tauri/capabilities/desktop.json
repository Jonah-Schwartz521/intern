{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-unregister-all",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-is-visible",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "notification:default",
    "dialog:allow-open",
    "clipboard-manager:allow-read-text",
    {
      "comment": "Read any file the user picks for the context bin. A reference file can live anywhere the user browses (Documents, but also project dirs like C:\\dev), so read is broad by necessity; narrow it to e.g. $HOME/** if you only ever add files from home. Read only, no write.",
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$TEMP/intern-voice-input.*" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$TEMP/intern-voice-input.*" }]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "schtasks",
          "cmd": "schtasks",
          "args": true
        },
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": true
        },
        {
          "comment": "Const-me whisper transcription. Resolved from the bundled resource dir ($RESOURCE); Whisper.dll sits next to main.exe in the same folder.",
          "name": "whisper-run",
          "cmd": "$RESOURCE/resources/whisper/main.exe",
          "args": ["-m", { "validator": ".+" }, "-f", { "validator": ".+" }, "-nt"]
        }
      ]
    },
    "autostart:default"
  ]
}